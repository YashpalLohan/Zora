<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ZORA | Error</title>
    <link rel="icon" href="/images/favicon.jpg">
    <link rel="stylesheet" href="/style/styles.css" />
</head>

<body>
    <div class="auth-container">
        <div class="auth-card" style="text-align: center;">
            <div class="auth-header">
                <div class="logo" style="font-size: 3rem; margin-bottom: 2rem;">!</div>
                <h1>Something went wrong</h1>
            </div>

            <p style="color: var(--text-secondary); margin-bottom: 2rem;">
                <%= error.message || 'The page you are looking for might have been moved or doesn\' t exist.' %>
            </p>

            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <a href="/home" class="btn btn-crimson">Go to Dashboard</a>
                <a href="javascript:history.back()" class="btn btn-outline">Go Back</a>
            </div>
        </div>
    </div>
</body>

</html>