<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= post.title %> | ZORA
    </title>
    <link rel="icon" href="/images/favicon.jpg">
    <link rel="stylesheet" href="/style/styles.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="/js/scripts.js"></script>
</head>

<body>
    <header>
        <div class="middle-nav">
            <div style="font-family: var(--font-heading); font-size: 0.8rem; font-weight: 700; width: 100px;">EST.
                2026<br>EDITION 01</div>
            <div class="brand-main">ARCHIVE</div>
            <div style="display: flex; gap: 1rem; align-items: center;">
                <a href="/home" class="btn-orange" style="padding: 0.5rem 1.5rem;">BACK</a>
                <% if (typeof currentUser !=='undefined' && currentUser) { %>
                    <a href="/home/create" class="btn-orange"
                        style="padding: 0.5rem 1.5rem; font-size: 0.8rem; border-radius: 4px;">PUBLISH</a>
                    <% } %>
            </div>

        </div>
    </header>

    <main>
        <section class="section-magazine editorial-grid" style="background: white;">
            <!-- Left Side: Large Image (Same style as homepage featured) -->
            <div style="width: 100%; aspect-ratio: 1/1.2; overflow: hidden; border: var(--border-thin);">
                <img src="<%= post.imageUrl || '/images/one.png' %>"
                    style="width: 100%; height: 100%; object-fit: cover;">
            </div>

            <!-- Right Side: Narrative Content -->
            <div style="padding-top: 4rem;">
                <div class="meta-info">
                    <%= new Date(post.createdAt).toLocaleDateString().toUpperCase() %>
                        &bull; BY <%= (post.author ? post.author.name || post.author.username : 'ANONYMOUS'
                            ).toUpperCase() %>
                </div>

                <h1 class="section-title">
                    <%= post.title %>
                </h1>

                <div
                    style="font-size: 1.25rem; line-height: 2; color: #333; margin-top: 2rem; white-space: pre-wrap; font-family: var(--font-body);">
                    <%= post.body %>
                </div>

                <% if (currentUser && (isAdmin || (post.author &&
                    post.author._id.toString()===currentUser._id.toString()))) { %>
                    <div
                        style="margin-top: 4rem; display: flex; gap: 1rem; border-top: var(--border-thin); padding-top: 2rem;">
                        <a href="/home/<%= post._id %>/edit" class="btn-orange">EDIT NARRATIVE</a>
                        <form action="/home/<%= post._id %>/delete" method="POST"
                            onsubmit="return confirmDelete(this, 'Permanently remove this archive entry?')">
                            <button type="submit" class="btn-orange btn-outline">DELETE</button>
                        </form>
                    </div>
                    <% } %>
            </div>
        </section>
    </main>

    <footer class="magazine-footer">
        <div class="brand-main" style="font-size: 4rem; letter-spacing: -2px; text-align: left;">ZORA</div>
    </footer>
</body>

</html>