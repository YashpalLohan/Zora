<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ZORA | Archive</title>
    <link rel="icon" href="/images/favicon.jpg">
    <link rel="stylesheet" href="/style/styles.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        .archive-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 4rem;
            padding: 6rem 4%;
        }

        .archive-item {
            border: var(--border-thin);
            background: white;
            transition: transform 0.3s ease;
        }

        .archive-item:hover {
            transform: translateY(-10px);
        }
    </style>
</head>

<body>
    <header>
        <div class="middle-nav">
            <div style="font-family: var(--font-heading); font-size: 0.8rem; font-weight: 700; width: 100px;">
                THE<br>ARCHIVE</div>
            <div class="brand-main">ZORA</div>
            <div style="display: flex; gap: 1rem; align-items: center;">
                <a href="/home" class="btn-orange" style="padding: 0.5rem 1.5rem;">HOME</a>
                <% if (typeof currentUser !=='undefined' && currentUser) { %>
                    <a href="/home/create" class="btn-orange"
                        style="padding: 0.5rem 1.5rem; font-size: 0.8rem; border-radius: 4px;">PUBLISH</a>
                    <% } %>
            </div>

        </div>
    </header>

    <main>
        <div class="section-magazine">
            <h1 class="section-title" style="text-align: center; font-size: 8rem; margin-bottom: 2rem;">THE
                COMPLETE<br>COLLECTION</h1>
            <p style="text-align: center; max-width: 600px; margin: 0 auto; color: #888;">Every narrative, every
                silhouette, every architectural vision preserved in the digital vault.</p>
        </div>

        <div class="archive-grid">
            <% posts.forEach(post=> { %>
                <div class="archive-item">
                    <div style="aspect-ratio: 1/1; overflow: hidden; border-bottom: var(--border-thin);">
                        <img src="<%= post.imageUrl || '/images/one.png' %>"
                            style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div style="padding: 2rem;">
                        <div class="meta-info">
                            <%= new Date(post.createdAt).toLocaleDateString() %>
                                <% if(post.author) { %> &bull; BY <%= post.author.name || post.author.username %>
                                        <% } %>
                        </div>
                        <h3 style="font-family: var(--font-heading); font-size: 1.5rem; text-transform: uppercase;">
                            <%= post.title %>
                        </h3>
                        <div style="margin-top: 2rem;">
                            <a href="/home/<%= post._id %>"
                                style="color: black; text-decoration: none; font-family: var(--font-heading); text-transform: uppercase; font-size: 0.8rem; border-bottom: 2px solid black;">Read
                                Narrative</a>
                        </div>
                    </div>
                </div>
                <% }); %>
        </div>
    </main>

    <footer class="magazine-footer"
        style="padding: 6rem 4% 4rem 4%; background: white; border-top: var(--border-thin);">
        <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 4rem; align-items: flex-start;">
            <div>
                <div class="brand-main"
                    style="font-size: 8rem; color: var(--accent-orange); letter-spacing: -4px; line-height: 0.8; margin-bottom: 2rem;">
                    ZORA</div>
                <p style="max-width: 500px; color: #666; font-size: 0.9rem; line-height: 1.8;">
                    Zora is a curated fashion magazine dedicated to high-fashion narratives and architectural design
                    research. Established in 2026, we serve as a definitive resource for curators, designers, and
                    historians seeking the intersection of movement and structure.
                </p>
            </div>
            <div>
                <h4
                    style="font-family: var(--font-heading); text-transform: uppercase; font-size: 0.9rem; margin-bottom: 2rem;">
                    EDITION 01</h4>
                <p style="font-size: 0.8rem; color: #888; line-height: 1.8;">
                    MAY 2026 / NEW YORK CITY<br>
                    PUBLISHED BY ZORA MEDIA GROUP<br>
                    PRINTED DIGITALLY WORLDWIDE
                </p>
            </div>
            <div>
                <h4
                    style="font-family: var(--font-heading); text-transform: uppercase; font-size: 0.9rem; margin-bottom: 2rem;">
                    NAVIGATION</h4>
                <p style="font-size: 0.8rem; color: #888; line-height: 1.8;">
                    <a href="/archive" style="color: inherit; text-decoration: none;">FULL ARCHIVE</a><br>
                    <a href="/contact" style="color: inherit; text-decoration: none;">CONTACT US</a><br>
                    <a href="/home" style="color: inherit; text-decoration: none;">BACK TO HOME</a>
                </p>
            </div>
        </div>
        <div
            style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #eee; font-size: 0.7rem; color: #aaa; text-transform: uppercase;">
            &copy; 2026 ZORA MAGAZINE. REDEFINING THE DIGITAL NARRATIVE.
        </div>
    </footer>
</body>

</html>